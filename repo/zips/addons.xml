version 0.3.0

Added Polish localization


version 0.2.0

Added option to record timeframe from channel list


version 0.1.0

Initial version.
    </news>
    <assets>
      <icon>icon.png</icon>
      <screenshot>resources/screenshots/screenshot-00.png</screenshot>
      <screenshot>resources/screenshots/screenshot-01.png</screenshot>
    </assets>
  </extension>
